<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style/output.css" />
    <title>The Meat-Hub</title>
    <style>
      @keyframes spin {
          from { transform: rotate(0deg); }
          to   { transform: rotate(360deg); }
      }
    ::-webkit-scrollbar {
      width: 3px; 
      height: 4px; 
    }

    ::-webkit-scrollbar-track {
      background: transparent; 
    }

    ::-webkit-scrollbar-thumb {
      background: linear-gradient(180deg, #ffffff, #ffffff);
      border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: linear-gradient(180deg, #7e7d7d, #5e5959); 
    }
  
    </style>
</head>
<body class="text-white">
<%- include("include/menu.ejs") -%>

<main class="w-full h-screen flex">
  <!-- 80% -->
  <div class="menu w-2/3 h-screen  text-white  flex flex-col gap-1 pl-3 pr-2 pt-6">
    
    <h2 class="text-center text-white text-2xl font-bold">Restaurant Menu</h2>
    <form method="get" action="/edit/restaurantMenu">
      <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-1.5 px-2.5 mt-2.5 rounded">Edit</button>
    </form>
    <div class="rData w-full  border-white-600 border-2 rounded flex h-full  overflow-y-auto">
      <ul class="flex flex-col w-full">
        <% if (rData) { %>
        <% for (let data of rData) { %>
            <li class="flex items-center justify-between  text-white p-2 hover:bg-red-600 transition duration-200 mb-1 w-full">
              <div>
                <span class="font-semibold text-lg"><%= data.itemName %></span>
                <span class="block text-sm text-gray-300">₹<%= data.itemPrice %></span>
                <input type="hidden" name="itemId" value="<%= data.id %>">
              </div>

              <div class="flex items-center gap-3">
             
         <!-- Subtract Button -->
          <button 
            type="button" 
            class="bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700"
            onclick="subtractFromOrder('<%= data.id %>')">−</button>

          <!-- Add Button -->
          <button
            type="button"
            class="bg-green-600 text-white px-3 py-1 rounded hover:bg-green-700"
            onclick="addToOrder('<%= data.itemName %>', <%= data.itemPrice %> , '<%= data.id %>')">
            Add
          </button>
              </div>
            </li>

        <% } %>
    <% } %>
      </ul>
      
    </div>

  <h3 class="text-center text-white text-2xl font-bold mt-2">Meat Shop Menu</h3>
    <form method="get" action="/edit/meatShopMenu">
      <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-1.5 px-2.5 rounded">Edit</button>
    </form>

  <div class="mData w-full border-2 border-white-600 flex h-full overflow-y-auto" >

      <ul class="flex flex-col w-full">
     <% if (mData) { %>
        <% for (let data of mData) { %>
      <li class="flex items-center justify-between  text-white p-2 hover:bg-red-600 transition duration-200 mb-1 w-full">
        <div class="flex flex-col">
          <span class="font-semibold text-lg"><%= data.itemName %></span>
          <span class="text-sm text-gray-300">₹<%= data.itemPrice %></span>
        </div>

        <div class="flex items-center gap-3">
          
       
       
         <!-- Subtract Button -->
          <button 
            type="button" 
            class="bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700"
            onclick="subtractFromOrder('<%= data.id %>')">−</button>

          <!-- Add Button -->
          <button
            type="button"
            class="bg-green-600 text-white px-3 py-1 rounded hover:bg-green-700"
            onclick="addToOrder('<%= data.itemName %>', <%= data.itemPrice %>, '<%= data.id %>')">
            Add
          </button>

        </div>
        </li>

          <% } %>
        <% } %>
    </ul>
  
    </div>
    
  </div>

  <!--20% -->
  <div class="w-1/3 border-l-2 border-white text-white p-2 overflow-y-auto">
  <div class="selection flex flex-col items-center justify-center h-screen p-6 rounded shadow text-center">
    <h1 class="text-white mb-24 text-xl font-semibold text-center">Order</h1>

    <!-- Order List -->
    <div class="orders bg-transparent overflow-auto w-full p-3 rounded" style="min-height: 370px; margin-bottom: 0.5rem;">
      <ol id="order-list" class="space-y-2 list-decimal list-inside bg-transparent w-full">
        <!-- Order items will be dynamically added here -->
      </ol>
    </div>

    <!-- Total Section -->
    <div class="total bg-transparent flex justify-between items-center mt-3 p-2 w-full rounded shadow-sm border-t border-gray-400">
      <h6 class="text-white font-medium">Total:</h6>
      <input id="total-price" value="₹0" readonly
        class="text-green-400 font-bold text-right bg-transparent border-none outline-none w-auto" />
    </div>

    <!-- Button Group -->
    <div class="flex justify-center gap-2 mt-4 w-full">
      <button onclick="placeOrder()" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded w-full transition duration-300">
        Place Order
      </button>
    </div>
  </div>
</div>

<div id="fullLoader" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 9999;
">
    <div style="
        width: 60px;
        height: 60px;
        border: 6px solid #ffffff;
        border-top: 6px solid transparent;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    "></div>
</div>




</main>
<script src="script/orders.js"></script>
</body>
</html>
