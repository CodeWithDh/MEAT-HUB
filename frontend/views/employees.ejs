<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style/output.css" />
    <title>Manage Employees - The Meat-Hub</title>
    <style>
    ::-webkit-scrollbar { width: 3px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: linear-gradient(180deg, #ffffff, #ffffff); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: linear-gradient(180deg, #7e7d7d, #5e5959); }
    </style>
</head>
<body class="text-white">
<%- include("include/menu.ejs") -%>

<main class="w-full h-screen flex">
  <div class="menu w-full h-screen text-white flex flex-col gap-6 p-6 overflow-y-auto">
    
    <!-- HEADER -->
    <div class="flex items-center justify-between border-b border-red-800 pb-4 relative">
      <h2 style="font-size: 2rem" class="text-3xl font-bold w-1/2 mx-auto text-center">Manage Employees</h2>
      <button onclick="window.history.back()" class="absolute right-0 top-0 bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded shadow border border-red-500 transition flex items-center gap-2">
        <span class="text-xl leading-none">&larr;</span> Back
      </button>
    </div>

    <!-- Add Employee Form -->
    <div class="bg-red-950 bg-opacity-50 p-6 rounded border border-red-900 shadow-lg mt-2">
        <h3 class="font-semibold mb-4 text-red-400 text-lg">Add New Employee</h3>
        <form method="POST" action="/employes" class="flex flex-wrap gap-4 items-end">
            <div class="flex flex-col flex-1 min-w-[150px]">
                <label class="text-xs text-gray-400 mb-1 uppercase tracking-wider font-semibold">Employee ID</label>
                <input type="text" name="employeeId" required class="bg-transparent border-b border-gray-500 text-white px-2 py-2 focus:border-blue-400 outline-none transition text-lg">
            </div>
            <div class="flex flex-col flex-1 min-w-[200px]">
                <label class="text-xs text-gray-400 mb-1 uppercase tracking-wider font-semibold">Name</label>
                <input type="text" name="employeeName" required class="bg-transparent border-b border-gray-500 text-white px-2 py-2 focus:border-blue-400 outline-none transition text-lg">
            </div>
            <div class="flex flex-col flex-1 min-w-[150px]">
                <label class="text-xs text-gray-400 mb-1 uppercase tracking-wider font-semibold">Joining Date</label>
                <input type="date" name="joiningDate" required class="bg-transparent border-b border-gray-500 text-gray-300 px-2 py-2 focus:border-blue-400 outline-none transition">
            </div>
            <div class="flex flex-col flex-1 min-w-[150px]">
                <label class="text-xs text-gray-400 mb-1 uppercase tracking-wider font-semibold">Salary (&#8377;)</label>
                <input type="number" name="salary" required class="bg-transparent border-b border-gray-500 text-white px-2 py-2 focus:border-blue-400 outline-none transition text-lg">
            </div>
            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded transition shadow-lg font-bold text-lg">Add Employee</button>
        </form>
    </div>

    <!-- Employee List -->
    <div class="overflow-hidden flex-1 mt-4 border border-red-900 rounded bg-red-950 bg-opacity-30 shadow-xl">
        <div class="overflow-y-auto h-full scrollbar-thin">
            <table class="w-full text-left border-collapse">
                <thead class="bg-red-900 sticky top-0 z-10 shadow">
                    <tr class="text-red-200 text-sm uppercase tracking-wider">
                        <th class="p-4 border-b border-red-800 font-semibold">ID</th>
                        <th class="p-4 border-b border-red-800 font-semibold">Name</th>
                        <th class="p-4 border-b border-red-800 font-semibold">Joining Date</th>
                        <th class="p-4 border-b border-red-800 font-semibold">Leaving Date</th>
                        <th class="p-4 border-b border-red-800 font-semibold">Salary (&#8377;)</th>
                        <th class="p-4 border-b border-red-800 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(typeof employees !== 'undefined' && employees.length > 0) { %>
                        <% employees.forEach(emp => { %>
                            <tr class="border-b border-red-900 hover:bg-red-900 hover:bg-opacity-30 transition">
                                <form method="POST" action="/employes/<%= emp.employeeId %>?_method=PUT">
                                    <td class="p-4 font-mono text-gray-300"><%= emp.employeeId %></td>
                                    <td class="p-4">
                                        <input type="text" name="employeeName" value="<%= emp.employeeName %>" required class="bg-transparent border-b border-gray-600 focus:border-red-400 text-white w-full px-2 py-1 transition">
                                    </td>
                                    <td class="p-4 text-gray-300">
                                        <%= new Date(emp.joiningDate).toISOString().split('T')[0] %>
                                    </td>
                                    <td class="p-4">
                                        <input type="date" name="leavingDate" value="<%= emp.leavingDate ? new Date(emp.leavingDate).toISOString().split('T')[0] : '' %>" class="bg-transparent border-b border-gray-600 focus:border-red-400 text-gray-300 w-full px-2 py-1 transition">
                                    </td>
                                    <td class="p-4">
                                        <input type="number" name="salary" value="<%= emp.salary %>" required class="bg-transparent border-b border-gray-600 focus:border-red-400 text-green-400 font-bold w-full px-2 py-1 transition">
                                    </td>
                                    <td class="p-4">
                                        <div class="flex justify-end gap-3">
                                            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded transition shadow font-medium">Save</button>
                                </form>
                                <form method="POST" action="/employes/<%= emp.employeeId %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to delete this employee completely?');">
                                            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded transition shadow font-medium">Delete</button>
                                </form>
                                        </div>
                                    </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="6" class="p-10 text-center text-gray-500 italic text-lg">No employees found. Add your first employee using the form above!</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

  </div>
</main>
</body>
</html>
