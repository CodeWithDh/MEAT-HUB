<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Arial', sans-serif; background-color: #f8f9fa; }
        .invoice-container { max-width: 800px; margin: 30px auto; background: #fff; padding: 20px; border-radius: 10px; box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1); }
        .invoice-header { border-bottom: 2px solid #ff0000; padding-bottom: 10px; }
        .invoice-header h1 { color: #ff0000; font-size: 24px; }
        .invoice-table { margin-top: 20px; }
        .table th { background-color: #ff0000; color: #fff; }
        .grand-total { background-color: #e9ecef; font-weight: bold; padding: 10px; }
    </style>
</head>
<body>

    <div class="invoice-container">
        <div class="invoice-header text-center">
            <h1>Invoice</h1>
            <p class="mb-1"><strong>Invoice Number:</strong> <%= data.invoiceNumber %></p>
            <p><strong>Date:</strong> <%= data.date %></p>
        </div>

        <h2 class="mt-4">Items</h2>
        <table class="table table-bordered table-striped invoice-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                <% data.items.forEach(item => { %>
                    <tr>
                        <td><%= item.itemName %></td>
                        <td><%= item.quantity %></td>
                        <td>₹<%= item.itemPrice %></td>
                        <td>₹<%= item.quantity * item.itemPrice %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="grand-total text-end mt-3">
            <h4>Grand Total: ₹<%= data.grandTotal %></h4>
        </div>
         <!-- QR Code Section -->
         <div class="text-center mt-4">
                <h5>Scan to Pay</h5>
                <img src="<%= QRCodePath %>" alt="UPI QR Code" style="width: 200px; height: 200px;">

        </div>
    </div>

</body>
</html>